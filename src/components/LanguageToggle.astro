---
import { languages, getLangFromUrl, ui } from "@/i18n";
import ColombiaFlag from "@/components/icons/Colombia.astro";
import USAFlag from "@/components/icons/USA.astro";

const currentLang = getLangFromUrl(Astro.url);

const LANGUAGES = Object.entries(languages).map(([code, name]) => ({
  code,
  name,
}));

// Serialize slugs for client-side use
const slugsData = {
  es: ui.es.slugs,
  en: ui.en.slugs,
};
const slugsJson = JSON.stringify(slugsData);
---

<div class="relative ml-1 mr-1 z-20" data-slugs={slugsJson}>
  <button
    data-transition-persist
    id="language-toggle-btn"
    class="appearance-none border-none flex hover:scale-125 hover:cursor-pointer transition"
  >
    <span class="sr-only">Cambiar idioma / Change language</span>
    {
      currentLang === "en" ? (
        <USAFlag class="size-5 rounded-sm" />
      ) : (
        <ColombiaFlag class="size-5 rounded-sm" />
      )
    }
  </button>
  <div
    data-transition-persist
    id="languages-menu"
    class="absolute hidden z-50 scale-80 top-8 right-0 text-sm p-1 min-w-32 rounded-md border border-gray-100 bg-white/90 dark:bg-gray-900/90 dark:border-gray-500/20 shadow-[0_3px_10px_rgb(0,0,0,0.2)] backdrop-blur-md"
  >
    <ul>
      {
        LANGUAGES.map(({ code, name }) => (
          <li
            class="languages-menu-option px-2 py-1.5 cursor-pointer hover:bg-neutral-400/40 dark:hover:bg-gray-500/50 rounded-sm"
            data-lang={code}
          >
            {name}
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  #languages-menu.open {
    display: inline;
    animation: scale-up-center 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes scale-up-center {
    from {
      transform: scale(0.8);
      opacity: 0;
    }

    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script is:inline>
  (function() {
    const languagesMenu = document.getElementById("languages-menu");
    let languageToggleBtn = document.getElementById("language-toggle-btn");

    // Función para manejar el toggle
    const toggleLanguageMenu = () => {
      const themesMenu = document.getElementById("themes-menu");
      if (themesMenu) themesMenu.classList.remove("open");

      const currentLang = window.location.pathname.startsWith("/es") ? "es" : "en";

      document.querySelectorAll(".languages-menu-option").forEach((element) => {
        const lang = element.getAttribute("data-lang");
        if (lang === currentLang) {
          element.classList.add("text-blue-500", "font-semibold");
        } else {
          element.classList.remove("text-blue-500", "font-semibold");
        }
      });

      const isClosed = !languagesMenu?.classList.contains("open");
      languagesMenu?.classList[isClosed ? "add" : "remove"]("open");
      if (languageToggleBtn)
        languageToggleBtn.setAttribute("aria-expanded", String(isClosed));
    };

    // Inicializar listeners
    if (languageToggleBtn) {
      languageToggleBtn.addEventListener("click", (e) => {
        if (e && e.stopPropagation) e.stopPropagation();
        toggleLanguageMenu();
      });
    }

    document.addEventListener("click", () => languagesMenu?.classList.remove("open"));

    // Lógica de navegación y traducción de hashes
    const toggleWrapper = document.querySelector("[data-slugs]");
    const slugsData = toggleWrapper ? JSON.parse(toggleWrapper.getAttribute("data-slugs") || "{}") : {};

    if (languagesMenu) {
      languagesMenu.addEventListener("click", (e) => {
        if (e && e.stopPropagation) e.stopPropagation();

        const target = e.target;
        const option = target.closest(".languages-menu-option");
        if (!option) return;

        const lang = option.getAttribute("data-lang");
        if (!lang) return;

        localStorage.setItem("language", lang);

        const currentPath = window.location.pathname;
        const currentHash = window.location.hash;
        const currentLang = currentPath.startsWith("/es") ? "es" : "en";
        let newPath = currentPath;

        if (lang === "en") {
          newPath = currentPath.replace(/^\/es(\/|$)/, "/");
        } else if (lang === "es") {
          if (!currentPath.startsWith("/es")) {
            newPath = "/es" + (currentPath === "/" ? "/" : currentPath);
          }
        }

        // Traducir hash
        let translatedHash = currentHash;
        if (currentHash && currentHash.startsWith("#")) {
          const hashValue = currentHash.substring(1);
          const fromSlugs = slugsData[currentLang] || {};
          const toSlugs = slugsData[lang] || {};
          const matchingKey = Object.keys(fromSlugs).find(key => fromSlugs[key] === hashValue);
          if (matchingKey && toSlugs[matchingKey]) {
            translatedHash = "#" + toSlugs[matchingKey];
          }
        }

        // Normalizar trailing slashes
        if (translatedHash) {
          if (!newPath.endsWith("/")) newPath += "/";
        } else if (newPath !== "/" && newPath.endsWith("/")) {
          newPath = newPath.slice(0, -1);
        }

        window.location.href = (newPath || "/") + translatedHash;
      });
    }

    // Soporte para Astro View Transitions
    document.addEventListener("astro:after-swap", () => {
      const btn = document.getElementById("language-toggle-btn");
      if (btn) {
        languageToggleBtn = btn;
        languageToggleBtn.addEventListener("click", (e) => {
          if (e && e.stopPropagation) e.stopPropagation();
          toggleLanguageMenu();
        });
      }
    });
  })();
</script>
